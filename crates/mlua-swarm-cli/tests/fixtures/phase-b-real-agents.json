{
  "id": "coding-orch-phase-b",
  "flow": {
    "kind": "seq",
    "children": [
      {
        "kind": "step",
        "ref": "topic-setup",
        "in": {
          "op": "path",
          "at": "$.d.topic_setup"
        },
        "out": {
          "op": "path",
          "at": "$.topic"
        }
      },
      {
        "kind": "branch",
        "cond": {
          "op": "eq",
          "lhs": {
            "op": "path",
            "at": "$.topic.parts[\"verdict\"]"
          },
          "rhs": {
            "op": "lit",
            "value": "BLOCKED"
          }
        },
        "then": {
          "kind": "assign",
          "at": {
            "op": "path",
            "at": "$.halted_at"
          },
          "value": {
            "op": "lit",
            "value": "topic-setup"
          }
        },
        "else": {
          "kind": "seq",
          "children": [
            {
              "kind": "step",
              "ref": "workspace-setup",
              "in": {
                "op": "path",
                "at": "$.d.workspace_setup"
              },
              "out": {
                "op": "path",
                "at": "$.workspace"
              }
            },
            {
              "kind": "branch",
              "cond": {
                "op": "eq",
                "lhs": {
                  "op": "path",
                  "at": "$.workspace.parts[\"verdict\"]"
                },
                "rhs": {
                  "op": "lit",
                  "value": "BLOCKED"
                }
              },
              "then": {
                "kind": "assign",
                "at": {
                  "op": "path",
                  "at": "$.halted_at"
                },
                "value": {
                  "op": "lit",
                  "value": "workspace-setup"
                }
              },
              "else": {
                "kind": "seq",
                "children": [
                  {
                    "kind": "step",
                    "ref": "context-librarian",
                    "in": {
                      "op": "path",
                      "at": "$.d.context"
                    },
                    "out": {
                      "op": "path",
                      "at": "$.context"
                    }
                  },
                  {
                    "kind": "branch",
                    "cond": {
                      "op": "eq",
                      "lhs": {
                        "op": "path",
                        "at": "$.context.parts[\"verdict\"]"
                      },
                      "rhs": {
                        "op": "lit",
                        "value": "BLOCKED"
                      }
                    },
                    "then": {
                      "kind": "assign",
                      "at": {
                        "op": "path",
                        "at": "$.halted_at"
                      },
                      "value": {
                        "op": "lit",
                        "value": "context-librarian"
                      }
                    },
                    "else": {
                      "kind": "seq",
                      "children": [
                        {
                          "kind": "step",
                          "ref": "impl-lead",
                          "in": {
                            "op": "path",
                            "at": "$.d.impl"
                          },
                          "out": {
                            "op": "path",
                            "at": "$.impl"
                          }
                        },
                        {
                          "kind": "branch",
                          "cond": {
                            "op": "eq",
                            "lhs": {
                              "op": "path",
                              "at": "$.impl.parts[\"verdict\"]"
                            },
                            "rhs": {
                              "op": "lit",
                              "value": "BLOCKED"
                            }
                          },
                          "then": {
                            "kind": "assign",
                            "at": {
                              "op": "path",
                              "at": "$.halted_at"
                            },
                            "value": {
                              "op": "lit",
                              "value": "impl-lead"
                            }
                          },
                          "else": {
                            "kind": "seq",
                            "children": [
                              {
                                "kind": "step",
                                "ref": "quality-coding",
                                "in": {
                                  "op": "path",
                                  "at": "$.d.qcode"
                                },
                                "out": {
                                  "op": "path",
                                  "at": "$.qcode"
                                }
                              },
                              {
                                "kind": "branch",
                                "cond": {
                                  "op": "eq",
                                  "lhs": {
                                    "op": "path",
                                    "at": "$.qcode.parts[\"verdict\"]"
                                  },
                                  "rhs": {
                                    "op": "lit",
                                    "value": "BLOCKED"
                                  }
                                },
                                "then": {
                                  "kind": "assign",
                                  "at": {
                                    "op": "path",
                                    "at": "$.halted_at"
                                  },
                                  "value": {
                                    "op": "lit",
                                    "value": "quality-coding"
                                  }
                                },
                                "else": {
                                  "kind": "seq",
                                  "children": [
                                    {
                                      "kind": "step",
                                      "ref": "quality-gate",
                                      "in": {
                                        "op": "path",
                                        "at": "$.d.qgate"
                                      },
                                      "out": {
                                        "op": "path",
                                        "at": "$.qgate_verdict"
                                      }
                                    },
                                    {
                                      "kind": "loop",
                                      "counter": {
                                        "op": "path",
                                        "at": "$.qg_n"
                                      },
                                      "cond": {
                                        "op": "and",
                                        "args": [
                                          {
                                            "op": "lt",
                                            "lhs": {
                                              "op": "path",
                                              "at": "$.qg_n"
                                            },
                                            "rhs": {
                                              "op": "lit",
                                              "value": 2
                                            }
                                          },
                                          {
                                            "op": "eq",
                                            "lhs": {
                                              "op": "path",
                                              "at": "$.qgate_verdict.parts[\"verdict\"]"
                                            },
                                            "rhs": {
                                              "op": "lit",
                                              "value": "BLOCKED"
                                            }
                                          }
                                        ]
                                      },
                                      "max": 3,
                                      "body": {
                                        "kind": "seq",
                                        "children": [
                                          {
                                            "kind": "step",
                                            "ref": "build-resolver",
                                            "in": {
                                              "op": "path",
                                              "at": "$.qgate_verdict"
                                            },
                                            "out": {
                                              "op": "path",
                                              "at": "$.resolve"
                                            }
                                          },
                                          {
                                            "kind": "step",
                                            "ref": "quality-gate",
                                            "in": {
                                              "op": "path",
                                              "at": "$.d.qgate"
                                            },
                                            "out": {
                                              "op": "path",
                                              "at": "$.qgate_verdict"
                                            }
                                          }
                                        ]
                                      }
                                    },
                                    {
                                      "kind": "branch",
                                      "cond": {
                                        "op": "eq",
                                        "lhs": {
                                          "op": "path",
                                          "at": "$.qgate_verdict.parts[\"verdict\"]"
                                        },
                                        "rhs": {
                                          "op": "lit",
                                          "value": "BLOCKED"
                                        }
                                      },
                                      "then": {
                                        "kind": "assign",
                                        "at": {
                                          "op": "path",
                                          "at": "$.halted_at"
                                        },
                                        "value": {
                                          "op": "lit",
                                          "value": "quality-gate"
                                        }
                                      },
                                      "else": {
                                        "kind": "seq",
                                        "children": [
                                          {
                                            "kind": "step",
                                            "ref": "committer",
                                            "in": {
                                              "op": "path",
                                              "at": "$.d.commit"
                                            },
                                            "out": {
                                              "op": "path",
                                              "at": "$.commit"
                                            }
                                          },
                                          {
                                            "kind": "branch",
                                            "cond": {
                                              "op": "eq",
                                              "lhs": {
                                                "op": "path",
                                                "at": "$.commit.parts[\"verdict\"]"
                                              },
                                              "rhs": {
                                                "op": "lit",
                                                "value": "BLOCKED"
                                              }
                                            },
                                            "then": {
                                              "kind": "assign",
                                              "at": {
                                                "op": "path",
                                                "at": "$.halted_at"
                                              },
                                              "value": {
                                                "op": "lit",
                                                "value": "committer"
                                              }
                                            },
                                            "else": {
                                              "kind": "seq",
                                              "children": [
                                                {
                                                  "kind": "step",
                                                  "ref": "worktree-merge",
                                                  "in": {
                                                    "op": "path",
                                                    "at": "$.d.merge"
                                                  },
                                                  "out": {
                                                    "op": "path",
                                                    "at": "$.merge"
                                                  }
                                                },
                                                {
                                                  "kind": "branch",
                                                  "cond": {
                                                    "op": "eq",
                                                    "lhs": {
                                                      "op": "path",
                                                      "at": "$.merge.parts[\"verdict\"]"
                                                    },
                                                    "rhs": {
                                                      "op": "lit",
                                                      "value": "BLOCKED"
                                                    }
                                                  },
                                                  "then": {
                                                    "kind": "assign",
                                                    "at": {
                                                      "op": "path",
                                                      "at": "$.halted_at"
                                                    },
                                                    "value": {
                                                      "op": "lit",
                                                      "value": "worktree-merge"
                                                    }
                                                  },
                                                  "else": {
                                                    "kind": "assign",
                                                    "at": {
                                                      "op": "path",
                                                      "at": "$.phase_b_complete"
                                                    },
                                                    "value": {
                                                      "op": "lit",
                                                      "value": true
                                                    }
                                                  }
                                                }
                                              ]
                                            }
                                          }
                                        ]
                                      }
                                    }
                                  ]
                                }
                              }
                            ]
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },
  "agents": [
    {
      "$agent_md": "topic-setup.md",
      "spec": {
        "operator_ref": "main-ai"
      }
    },
    {
      "$agent_md": "workspace-setup.md",
      "spec": {
        "operator_ref": "main-ai"
      }
    },
    {
      "$agent_md": "context-librarian.md",
      "spec": {
        "operator_ref": "main-ai"
      }
    },
    {
      "$agent_md": "impl-lead.md",
      "spec": {
        "operator_ref": "main-ai"
      }
    },
    {
      "$agent_md": "quality-coding.md",
      "spec": {
        "operator_ref": "main-ai"
      }
    },
    {
      "$agent_md": "quality-gate.md",
      "verdict": {
        "channel": "part",
        "values": ["PASS", "BLOCKED"]
      },
      "spec": {
        "operator_ref": "main-ai"
      }
    },
    {
      "$agent_md": "committer.md",
      "spec": {
        "operator_ref": "main-ai"
      }
    },
    {
      "$agent_md": "worktree-merge.md",
      "spec": {
        "operator_ref": "main-ai"
      }
    },
    {
      "$agent_md": "build-resolver.md",
      "spec": {
        "operator_ref": "main-ai"
      }
    }
  ],
  "strategy": {
    "strict_refs": true,
    "strict_kind": true
  },
  "metadata": {
    "default_run_ttl_secs": 5400,
    "description": "Real-world coding-pipeline shape: nine verdict-gated stages in sequence with a bounded fix-and-regate retry loop around the quality gate. Callers seed per-stage directives under init_ctx.d and the retry counter qg_n=0. The quality-gate agent declares a verdict contract (channel=part, values=[PASS, BLOCKED]) so compile-time cond lint and submit-time gating protect the loop shape."
  },
  "operators": [
    {
      "name": "main-ai",
      "display_name": "Main AI (Coding Orch dispatcher)",
      "kind": "main_ai",
      "spec": {}
    }
  ]
}
